[
  {
    "id": "myrealm",
    "realm": "myrealm",
    "enabled": true,
    "clients": [
      {
        "clientId": "springboot-app",
        "enabled": true,
        "publicClient": false,
        "secret": "secret123",
        "redirectUris": ["http://localhost:8080/swagger-ui/oauth2-redirect.html"],
        "protocol": "openid-connect",
        "standardFlowEnabled": true,
        "directAccessGrantsEnabled": true,
        "protocolMappers": [
          {
            "name": "tenant_id",
            "protocol": "openid-connect",
            "protocolMapper": "oidc-usermodel-attribute-mapper",
            "config": {
              "user.attribute": "tenant_id",
              "claim.name": "tenant_id",
              "jsonType.label": "String",
              "id.token.claim": "true",
              "access.token.claim": "true",
              "userinfo.token.claim": "true"
            }
          }
        ]
      }
    ],
    "roles": {
      "realm": [
        {
          "name": "USER"
        },
        {
          "name": "ADMIN"
        }
      ]
    },
    "users": [
      {
        "username": "user1",
        "firstName": "user1",
        "lastName": "test",
        "email": "user1@gmail.com",
        "enabled": true,
        "attributes": {
          "tenant_id": ["tenant-a"]
        },
        "credentials": [
          {
            "type": "password",
            "value": "userpass",
            "temporary": false
          }
        ],
        "realmRoles": ["USER"]
      },
      {
        "username": "admin1",
        "firstName": "admin1",
        "lastName": "test",
        "email": "admin1@gmail.com",
        "enabled": true,
        "attributes": {
          "tenant_id": ["tenant-b"]
        },
        "credentials": [
          {
            "type": "password",
            "value": "adminpass",
            "temporary": false
          }
        ],
        "realmRoles": ["USER", "ADMIN"]
      }
    ]
  }
]
